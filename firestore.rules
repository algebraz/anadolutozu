rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "zaferozlu@gmail.com" || 
        request.auth.uid == "5flA6J5d1JMuOZdO9bwsh3IiOnd2"
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isStringWithMaxSize(val, maxSize) {
      return val is string && val.size() <= maxSize;
    }

    function isOptionalStringWithMaxSize(field, maxSize) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null || 
             (request.resource.data[field] is string && request.resource.data[field].size() <= maxSize);
    }

    function isValidComment() {
      let allowedFields = ['postId', 'userId', 'userName', 'userPhoto', 'text', 'createdAt'];
      let requiredFields = ['postId', 'userId', 'userName', 'text', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isStringWithMaxSize(request.resource.data.postId, 100) &&
             request.resource.data.userId == request.auth.uid &&
             isStringWithMaxSize(request.resource.data.userName, 100) &&
             isOptionalStringWithMaxSize('userPhoto', 1000) &&
             isStringWithMaxSize(request.resource.data.text, 2000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidUser() {
      let allowedFields = ['email', 'role', 'createdAt'];
      let requiredFields = ['email', 'role', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isStringWithMaxSize(request.resource.data.email, 200) &&
             (request.resource.data.role == 'admin' || request.resource.data.role == 'user') &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidComment();
      allow update: if isOwner(resource.data.userId) && 
                       isValidComment() && 
                       request.resource.data.postId == resource.data.postId &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin() || true; // Temporarily allow read to fix permission issues during init
      
      // Only admins can create/update roles, OR user can create their own profile with 'user' role
      allow create: if isAuthenticated() && isValidUser() && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == 'user')
      );
      
      allow update: if isAuthenticated() && isValidUser() && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.createdAt == resource.data.createdAt)
      );
      
      allow delete: if isAdmin();
    }
  }
}
